# Oracle FCC MCP Server — Single-Tenant Configuration
# Copy this to .env and fill in your values

# Required: FCC environment URL (do not include /HyperionPlanning or /interop)
FCC_URL=https://myenv-mycompany.epm.us2.oraclecloud.com

# Required: FCC application name
FCC_APP_NAME=MyFCCApp

# Auth method: "basic" or "oauth"
FCC_AUTH_METHOD=basic

# --- Basic Auth (FCC_AUTH_METHOD=basic) ---
FCC_USERNAME=user@company.com
FCC_PASSWORD=YourPassword123

# --- OAuth 2.0 Device Code Flow (FCC_AUTH_METHOD=oauth) ---
# FCC_IDCS_URL=https://idcs-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.identity.oraclecloud.com
# FCC_CLIENT_ID=your_client_id
# FCC_CLIENT_SECRET=your_client_secret   # Only for confidential client registrations

# --- Multi-tenant (overrides all above) ---
# FCC_TENANTS_CONFIG=C:/path/to/tenants.json
